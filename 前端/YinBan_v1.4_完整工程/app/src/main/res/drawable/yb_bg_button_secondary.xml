<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/yb_color_primary_container" />
            <corners android:radius="@dimen/yb_radius_button" />
            <stroke
                android:width="1dp"
                android:color="@color/yb_color_primary" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/yb_color_surface" />
            <corners android:radius="@dimen/yb_radius_button" />
            <stroke
                android:width="1dp"
                android:color="@color/yb_color_border" />
        </shape>
    </item>
</selector>
