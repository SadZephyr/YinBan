<?xml version="1.0" encoding="utf-8"?>
<!-- 我的 Fragment：T1 深色视觉重设计，保留原 ID 与业务绑定 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/yb_night_bg_page"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/yb_spacing_page_horizontal"
        android:paddingTop="@dimen/yb_spacing_24"
        android:paddingEnd="@dimen/yb_spacing_page_horizontal"
        android:paddingBottom="@dimen/yb_spacing_24">

        <!-- 账户身份卡 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/yb_color_night_surface_strong"
            app:cardCornerRadius="@dimen/yb_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/yb_color_night_border_strong"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/yb_spacing_20">

                <FrameLayout
                    android:id="@+id/avatar_container"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/yb_me_bg_avatar"
                    android:clickable="true"
                    android:contentDescription="点击更换头像"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/iv_avatar_photo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:contentDescription="当前头像照片"
                        android:scaleType="fitCenter"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_avatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="🧑"
                        android:textSize="34sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/yb_spacing_16"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/group_nickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:contentDescription="点击编辑昵称"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="@dimen/yb_size_touch_target_min"
                        android:orientation="horizontal"
                        android:paddingEnd="@dimen/yb_spacing_8">

                        <TextView
                            android:id="@+id/tv_profile_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:text="昵称"
                            android:textColor="@color/yb_color_night_text_primary"
                            android:textSize="22sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="@dimen/yb_spacing_8"
                            android:contentDescription="@null"
                            android:src="@drawable/yb_ic_me_edit"
                            app:tint="@color/yb_color_night_text_muted" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_profile_account"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="账号"
                        android:textColor="@color/yb_color_night_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/chip_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/yb_me_bg_role_chip"
                    android:gravity="center"
                    android:minHeight="30dp"
                    android:paddingHorizontal="@dimen/yb_spacing_12"
                    android:paddingVertical="@dimen/yb_spacing_4"
                    android:text="患者"
                    android:textColor="@color/yb_color_night_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 提示设置 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_prompt_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/yb_spacing_16"
            app:cardBackgroundColor="@color/yb_color_night_surface"
            app:cardCornerRadius="@dimen/yb_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/yb_color_night_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/yb_spacing_20"
                android:paddingVertical="@dimen/yb_spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/yb_spacing_8"
                    android:fontFamily="sans-serif-medium"
                    android:text="提示设置"
                    android:textColor="@color/yb_color_night_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="振动提醒"
                        android:textColor="@color/yb_color_night_text_primary"
                        android:textSize="16sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_vibration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/yb_size_touch_target_min"
                        app:thumbTint="@color/yb_night_switch_thumb"
                        app:trackTint="@color/yb_night_switch_track" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/yb_color_night_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="语音播报"
                        android:textColor="@color/yb_color_night_text_primary"
                        android:textSize="16sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_voice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/yb_size_touch_target_min"
                        app:thumbTint="@color/yb_night_switch_thumb"
                        app:trackTint="@color/yb_night_switch_track" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI 设置 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ai_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/yb_spacing_16"
            app:cardBackgroundColor="@color/yb_color_night_surface"
            app:cardCornerRadius="@dimen/yb_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/yb_color_night_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/yb_spacing_20">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/yb_size_icon"
                        android:layout_height="@dimen/yb_size_icon"
                        android:contentDescription="@null"
                        android:src="@drawable/yb_ic_me_ai"
                        app:tint="@color/yb_color_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/yb_spacing_8"
                        android:fontFamily="sans-serif-medium"
                        android:text="AI 设置"
                        android:textColor="@color/yb_color_night_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/group_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/yb_spacing_12"
                    android:clickable="true"
                    android:contentDescription="点击设置DeepSeek API Key"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="64dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DeepSeek API Key"
                            android:textColor="@color/yb_color_night_text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tv_api_key_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="未设置 · 使用内置Key"
                            android:textColor="@color/yb_color_night_text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/yb_size_icon"
                        android:layout_height="@dimen/yb_size_icon"
                        android:layout_marginStart="@dimen/yb_spacing_16"
                        android:contentDescription="@null"
                        android:src="@drawable/yb_ic_me_settings"
                        app:tint="@color/yb_color_night_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 关于 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/yb_spacing_16"
            app:cardBackgroundColor="@color/yb_color_night_surface"
            app:cardCornerRadius="@dimen/yb_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/yb_color_night_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/yb_spacing_20"
                android:paddingVertical="@dimen/yb_spacing_12">

                <ImageView
                    android:layout_width="@dimen/yb_size_icon"
                    android:layout_height="@dimen/yb_size_icon"
                    android:contentDescription="@null"
                    android:src="@drawable/yb_ic_me_info"
                    app:tint="@color/yb_color_night_text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/yb_spacing_12"
                    android:layout_weight="1"
                    android:text="关于"
                    android:textColor="@color/yb_color_night_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="版本 1.2.0"
                    android:textColor="@color/yb_color_night_text_muted"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 退出按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/yb_size_button_height"
            android:layout_marginTop="@dimen/yb_spacing_24"
            android:contentDescription="退出登录按钮"
            android:text="退出登录"
            android:textColor="@color/yb_color_status_danger"
            android:textSize="15sp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="@dimen/yb_radius_medium"
            app:icon="@drawable/yb_ic_me_logout"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/yb_spacing_8"
            app:iconTint="@color/yb_color_status_danger"
            app:strokeColor="@color/yb_color_status_danger"
            app:strokeWidth="1dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="112dp" />

    </LinearLayout>
</ScrollView>
